<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>

<AnchorPane prefHeight="600" prefWidth="800" style="-fx-background-color: linear-gradient(to bottom right, #0f0c29, #302b63, #24243e);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.example.resono.VideoController">

    <VBox alignment="CENTER" layoutX="100" layoutY="50" spacing="10">

        <MediaView fx:id="mediaView" fitHeight="300.0" fitWidth="600.0" style="-fx-background-color: black; -fx-border-color: white; -fx-border-radius: 10px;" />

        <Slider fx:id="progressSlider" style="-fx-pref-width: 600px;" />

        <HBox fx:id="controlsContainer" alignment="CENTER" spacing="20">
            <Button fx:id="rewindButton" style="-fx-background-color: #ff4b2b; -fx-text-fill: white; -fx-background-radius: 10px;" text="Rewind" />
            <Button fx:id="playPauseButton" style="-fx-background-color: #ff4b2b; -fx-text-fill: white; -fx-background-radius: 10px;" text="Play" />
            <Button fx:id="forwardButton" style="-fx-background-color: #ff4b2b; -fx-text-fill: white; -fx-background-radius: 10px;" text="Forward" />
<!--            <Button fx:id="fullscreenButton" style="-fx-background-color: #ff4b2b; -fx-text-fill: white; -fx-background-radius: 10px;" text="Fullscreen" />-->
        </HBox>

        <Slider fx:id="volumeSlider" style="-fx-pref-width: 200px;" />

    </VBox>
</AnchorPane>
